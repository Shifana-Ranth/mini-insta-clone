<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <servlet>
        <servlet-name>PostServlet</servlet-name>
        <servlet-class>com.miniinstagram.post.servlet.PostServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>PostServlet</servlet-name>
        <url-pattern>/posts</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UserPostsServlet</servlet-name>
        <servlet-class>com.miniinstagram.post.servlet.UserPostsServlet</servlet-class>
    </servlet>

<servlet>
    <servlet-name>TrendingPostsServlet</servlet-name>
    <servlet-class>com.miniinstagram.post.servlet.TrendingPostsServlet</servlet-class>
</servlet>

<servlet>
    <servlet-name>PostsByUserIdsServlet</servlet-name>
    <servlet-class>com.miniinstagram.post.servlet.PostsByUserIdsServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>PostsByUserIdsServlet</servlet-name>
    <url-pattern>/postsByUserIds</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>TrendingPostsServlet</servlet-name>
    <url-pattern>/getTrendingPosts</url-pattern>
</servlet-mapping>

    <servlet-mapping>
        <servlet-name>UserPostsServlet</servlet-name>
        <url-pattern>/userPosts</url-pattern>
    </servlet-mapping>

	<servlet>
	    <servlet-name>DeletePostServlet</servlet-name>
	    <servlet-class>com.miniinstagram.post.servlet.DeletePostServlet</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>DeletePostServlet</servlet-name>
	    <url-pattern>/deletePost</url-pattern>
	</servlet-mapping>
	
	<servlet>
    <servlet-name>PostCountServlet</servlet-name>
    <servlet-class>com.miniinstagram.post.servlet.PostCountServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>PostCountServlet</servlet-name>
    <url-pattern>/getPostCount</url-pattern>
</servlet-mapping>
</web-app>